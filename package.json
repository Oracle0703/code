{
  "name": "daily-workbench",
  "productName": "Daily Workbench",
  "version": "0.1.0",
  "description": "A personal Electron workspace for tasks, notes, browsing, and terminal workflows.",
  "main": ".vite/build/main.js",
  "private": true,
  "author": "Oracle0703",
  "license": "MIT",
  "scripts": {
    "clean": "node scripts/clean.mjs",
    "prestart": "npm run clean",
    "start": "electron-forge start",
    "prepackage": "npm run clean",
    "package": "electron-forge package",
    "prepackage:linux": "npm run clean",
    "package:linux": "electron-forge package --platform=linux --arch=x64",
    "premake": "npm run clean",
    "make": "electron-forge make",
    "premake:windows": "npm run clean",
    "make:windows": "electron-forge make --platform=win32 --arch=x64",
    "lint": "eslint . --max-warnings=0",
    "typecheck": "tsc -p tsconfig.main.json && tsc -p tsconfig.renderer.json && tsc -p tsconfig.tools.json",
    "test": "vitest run",
    "test:watch": "vitest",
    "audit:all": "node scripts/audit-dependencies.mjs",
    "audit:prod": "npm audit --omit=dev --audit-level=info",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "check": "npm run format:check && npm run lint && npm run typecheck && npm run test && npm run audit:all && npm run audit:prod && npm run package"
  },
  "dependencies": {
    "@xterm/addon-fit": "0.11.0",
    "@xterm/xterm": "6.0.0",
    "electron-squirrel-startup": "1.0.1",
    "lucide-react": "^1.25.0",
    "node-pty": "1.1.0",
    "react": "^19.2.8",
    "react-dom": "^19.2.8"
  },
  "devDependencies": {
    "@electron-forge/cli": "7.11.2",
    "@electron-forge/maker-deb": "7.11.2",
    "@electron-forge/maker-rpm": "7.11.2",
    "@electron-forge/maker-squirrel": "7.11.2",
    "@electron-forge/maker-zip": "7.11.2",
    "@electron-forge/plugin-auto-unpack-natives": "7.11.2",
    "@electron-forge/plugin-fuses": "7.11.2",
    "@electron-forge/plugin-vite": "7.11.2",
    "@electron-forge/shared-types": "7.11.2",
    "@electron/fuses": "2.1.3",
    "@eslint/js": "^10.0.1",
    "@types/node": "^24.13.3",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "4.7.0",
    "electron": "43.2.0",
    "eslint": "^10.7.0",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.3",
    "globals": "^17.7.0",
    "prettier": "^3.9.6",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.65.0",
    "vite": "6.4.3",
    "vitest": "3.2.7"
  },
  "packageManager": "npm@11.9.0",
  "devEngines": {
    "runtime": {
      "name": "node",
      "version": "24.14.0",
      "onFail": "error"
    },
    "packageManager": {
      "name": "npm",
      "version": "11.9.0",
      "onFail": "error"
    }
  },
  "engines": {
    "node": ">=24.14.0 <25",
    "npm": ">=11.9.0 <12"
  }
}
